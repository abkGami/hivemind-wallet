# ── Solana ────────────────────────────────────────────────────
# Helius devnet RPC endpoint (free tier).
# SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_RPC_URL=https://solana-devnet.g.alchemy.com/v2/0jyTmYXyvdZEslnSkpkLd

# Deployed Anchor program address (set after `anchor deploy`).
COLONY_PROGRAM_ID=2wRN9Nrd5USVo5oVWjyfYiRgN6nrJMW5vDpscx7iRRZn

# Authority keypair as a JSON byte array: [1,2,3,...,64]
# Generated with: solana-keygen new --outfile /tmp/authority.json
# Then: cat /tmp/authority.json
# NEVER commit real key bytes.
